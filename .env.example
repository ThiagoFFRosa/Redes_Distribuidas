# Servidor
LOG_LEVEL=info
PORT=3000
SERVER_NAME=server_a
SERVER_URL=http://127.0.0.1:3000

# Cluster
CLUSTER_KEY=changeme_cluster_key
INITIAL_ROLE=STANDBY

# Autenticação
ADMIN_USER=admin
ADMIN_PASSWORD=changeme_admin_password
SESSION_SECRET=changeme_session_secret

# Heartbeat
HEARTBEAT_INTERVAL_MS=3000
HEARTBEAT_TIMEOUT_MS=9000

# ngrok
ENABLE_NGROK=true
NGROK_AUTHTOKEN=
NGROK_REGION=sa
NGROK_DOMAIN=

PUBLIC_URL_CHECK_INTERVAL_MS=30000
PUBLIC_URL_CHECK_TIMEOUT_MS=3000
# Sync
SYNC_BATCH_SIZE=100
SYNC_MAX_PAYLOAD_BYTES=512000
SYNC_MAX_BATCHES_PER_CYCLE=5
SYNC_DEDUPE_WINDOW_MS=2000
