PORT=3000
SERVER_NAME=server_a
SERVER_URL=http://100.x.x.x:3000
CLUSTER_KEY=uma-chave-secreta-do-cluster
CLUSTER_NODES_FILE=cluster-nodes.json

# Opcional: fallback legado para bootstrap de peers
PEERS=

INITIAL_ROLE=HOST

ADMIN_USER=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=dev-secret

HEARTBEAT_INTERVAL_MS=3000
HEARTBEAT_TIMEOUT_MS=9000

ENABLE_NGROK=true
NGROK_AUTHTOKEN=
NGROK_REGION=sa

# Opcional: domínio fixo do plano pago do ngrok
# Se vazio, o sistema usa URL dinâmica
NGROK_DOMAIN=
