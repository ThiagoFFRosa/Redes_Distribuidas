# Servidor
LOG_LEVEL=info
PORT=3000
BIND_HOST=0.0.0.0
SERVER_NAME=server_a
SERVER_URL=http://127.0.0.1:3000

# Cluster
CLUSTER_KEY=changeme_cluster_key
INITIAL_ROLE=STANDBY

# Autenticação
SESSION_SECRET=changeme_session_secret
JWT_SECRET=dev_secret_change_me

# Banco MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=redes_distribuidas
DB_CONNECTION_LIMIT=10

# Heartbeat
HEARTBEAT_INTERVAL_MS=3000
HEARTBEAT_TIMEOUT_MS=9000

# ngrok
ENABLE_NGROK=true
NGROK_AUTHTOKEN=
NGROK_REGION=sa
NGROK_DOMAIN=

PUBLIC_URL_CHECK_INTERVAL_MS=30000
PUBLIC_URL_CHECK_TIMEOUT_MS=3000
# Join/bootstrap automático (desabilitado por padrão em desenvolvimento)
AUTO_JOIN_HOST_ON_STARTUP=false
AUTO_JOIN_HOST_URL=
AUTO_BOOTSTRAP_ON_JOIN=false

# Sync
SYNC_BATCH_SIZE=100
SYNC_MAX_PAYLOAD_BYTES=512000
SYNC_MAX_BATCHES_PER_CYCLE=5
SYNC_DEDUPE_WINDOW_MS=2000

CHART_JOB_TIMEOUT_SECONDS=60
NGROK_CHECK_INTERVAL_MS=10000
NGROK_TAKEOVER_GRACE_MS=10000
